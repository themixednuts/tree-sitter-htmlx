{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "css",
      "camelcase": "CSS",
      "scope": "source.css",
      "external-files": ["src/scanner.c"],
      "file-types": ["css"],
      "injection-regex": "^css$",
      "highlights": "queries/highlights.scm"
    }
  ],
  "metadata": {
    "version": "0.1.7",
    "license": "MIT",
    "description": "Extended CSS grammar for the Svelte toolchain",
    "authors": [
      {
        "name": "mixednuts"
      }
    ],
    "links": {
      "repository": "https://github.com/themixednuts/tree-sitter-htmlx"
    }
  },
  "bindings": {
    "rust": true
  }
}
