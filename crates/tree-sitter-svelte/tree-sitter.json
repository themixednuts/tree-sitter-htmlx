{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "svelte",
      "camelcase": "Svelte",
      "scope": "source.svelte",
      "external-files": [
        "src/htmlx/html/tag.h",
        "src/htmlx/html/scanner.c",
        "src/htmlx/scanner.c"
      ],
      "file-types": ["svelte"],
      "injection-regex": "^svelte$",
      "highlights": "queries/highlights.scm",
      "injections": ["queries/htmlx/injections.scm", "queries/injections.scm"],
      "folds": "queries/folds.scm",
      "indents": "queries/indents.scm",
      "locals": "queries/locals.scm"
    }
  ],
  "metadata": {
    "version": "0.1.14",
    "license": "MIT",
    "description": "Svelte 5 grammar for tree-sitter",
    "authors": [
      {
        "name": "mixednuts"
      }
    ],
    "links": {
      "repository": "https://github.com/themixednuts/tree-sitter-htmlx"
    }
  },
  "bindings": {
    "rust": true
  }
}
